# Example /etc/default/wireguard-egress-aws-sync configuration
# Copy to /etc/default/wireguard-egress-aws-sync on EC2 if using AWS tag-driven switching.

# Enable AWS Console egress mode switching via instance tags
ENABLE_AWS_CONSOLE_EGRESS_SWITCH="false"

# EC2 instance tag key to read for egress mode
AWS_EGRESS_TAG_KEY="wireguard-egress-mode"
