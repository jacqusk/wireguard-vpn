# Example /etc/default/wireguard-egress configuration
# Copy to /etc/default/wireguard-egress on EC2 and fill in real values.

# Egress mode: direct | residential-proxy
EGRESS_MODE="direct"

# Proxy type: socks5 | http-connect
RESIDENTIAL_PROXY_TYPE="socks5"

# Upstream residential proxy connection
RESIDENTIAL_PROXY_HOST="proxy.example.com"
RESIDENTIAL_PROXY_IP=""
RESIDENTIAL_PROXY_PORT="1080"
RESIDENTIAL_PROXY_USERNAME=""
RESIDENTIAL_PROXY_PASSWORD=""

# Local redsocks listener port for TCP redirect
RESIDENTIAL_PROXY_LOCAL_PORT="12345"

# Optional UDP relay (requires socks5 with UDP ASSOCIATE support)
ENABLE_SOCKS5_UDP_SUPPORT="false"
RESIDENTIAL_PROXY_UDP_LOCAL_PORT="12346"
