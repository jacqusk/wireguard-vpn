# Fill this before the real deployment. Do not commit real values with secrets.

# Mandatory account and repository alignment
TARGET_AWS_ACCOUNT_NAME="REPLACE_WITH_TARGET_AWS_ACCOUNT_NAME"
TARGET_AWS_ACCOUNT_ID="REPLACE_WITH_TARGET_AWS_ACCOUNT_ID"
TARGET_AWS_REGION="eu-central-1"
TARGET_GITHUB_OWNER="REPLACE_WITH_TARGET_GITHUB_OWNER"
TARGET_GITHUB_REPO="REPLACE_WITH_TARGET_GITHUB_REPO"
TARGET_GITHUB_BRANCH="main"

# Optional override. Leave empty to use the public GitHub branch archive URL.
# If the repo is private, set this to an accessible tar.gz source such as S3.
DEPLOYMENT_SOURCE_URL=""

# Naming used during the first rollout
EC2_INSTANCE_NAME="wireguard-vpn-v1"
SECURITY_GROUP_NAME="wireguard-vpn-v1-sg"
ELASTIC_IP_NAME="wireguard-vpn-v1-eip"

# Operational decisions for the first rollout
FIRST_ROLLOUT_MODE="direct-only"
ALLOW_SSH="false"
ALLOW_SSM="false"
ENABLE_AWS_CONSOLE_EGRESS_SWITCH="false"
ENABLE_RESIDENTIAL_PROXY="false"
ENABLE_UDP_RELAY="false"

# First test clients
PRIMARY_TEST_PEER_NAME="phone-test-1"
SECONDARY_TEST_PEER_NAME="cloud-test-1"
CLIENT_DNS="1.1.1.1"