/etc/sing-box/
wg-residential-udp-relay.json
wg-residential-proxy.conf

# Generated artifacts
generated/

# Logs and local scratch files
*.log
*.tmp
*.bak
*.swp

# OS/editor noise
.DS_Store
Thumbs.db
desktop.ini